# 包含 web 前端源码
recursive-include web/app *
recursive-include web/components *
recursive-include web/lib *
recursive-include web/public *
include web/*.json web/*.js web/*.ts web/*.mjs web/*.css web/__init__.py

# 排除运行时和依赖目录
prune web/node_modules
prune web/.next

# 核心模块（已在 packages 中，但确保 sdist 完整）
recursive-include core *.py
recursive-include api *.py

