# Co-Thinker 配置模板
# 复制此文件为 .env 后填写真实值

# DeepSeek Chat API（用于答案生成和检索）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 数据与存储路径
DATA_DIR=data
VECTORSTORE_DIR=vectorstore
STORAGE_DIR=storage

# 文档分块参数
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# 检索参数
TOP_K=5
RETRIEVAL_CANDIDATE_K=20
SIMILARITY_CUTOFF=0.25
RRF_K=60
VECTOR_WEIGHT=0.55
BM25_WEIGHT=0.45

# 生成参数
MAX_TOKENS=2048
TEMPERATURE=0.2
CONTEXT_TOKEN_BUDGET=6000
MAX_HISTORY_TURNS=10

# 日志级别
LOG_LEVEL=INFO
